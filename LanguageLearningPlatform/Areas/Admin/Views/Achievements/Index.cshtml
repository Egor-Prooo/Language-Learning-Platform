@model IEnumerable<LanguageLearningPlatform.Data.Models.Achievement>

@{
    ViewData["Title"] = "Achievements";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0"><i class="fas fa-trophy me-2"></i>Achievements</h1>
        <p class="text-muted small mb-0">@Model.Count() total achievements</p>
    </div>
    <a asp-area="Admin" asp-controller="Achievements" asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>New Achievement
    </a>
</div>

<!-- Stats Bar -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#F59E0B;">
            <div class="fw-bold" style="font-size:1.5rem;color:#F59E0B;">@Model.Count()</div>
            <div class="text-muted small">Total</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#8B5CF6;">
            <div class="fw-bold" style="font-size:1.5rem;color:#8B5CF6;">@Model.Count(a => a.IsRare)</div>
            <div class="text-muted small">Rare</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#10B981;">
            <div class="fw-bold" style="font-size:1.5rem;color:#10B981;">@Model.Sum(a => a.UserAchievements.Count)</div>
            <div class="text-muted small">Times Unlocked</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#4F46E5;">
            <div class="fw-bold" style="font-size:1.5rem;color:#4F46E5;">@Model.Select(a => a.Category).Distinct().Count()</div>
            <div class="text-muted small">Categories</div>
        </div>
    </div>
</div>

<!-- Filter Bar -->
<div class="admin-card mb-4">
    <div class="admin-card-body">
        <div class="row g-3">
            <div class="col-md-5">
                <input type="text" id="achievementSearch" class="form-control" placeholder="Search by title or description" />
            </div>
            <div class="col-md-3">
                <select id="categoryFilter" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Select(a => a.Category).Distinct().OrderBy(c => c))
                    {
                        <option>@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select id="rareFilter" class="form-select">
                    <option value="">All Types</option>
                    <option value="rare">Rare</option>
                    <option value="common">Common</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" id="clearFilters">
                    <i class="fas fa-times me-1"></i>Clear
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Achievements Table -->
<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Achievement</th>
                        <th>Category</th>
                        <th>Points Required</th>
                        <th>Points Reward</th>
                        <th>Rarity</th>
                        <th>Unlocked By</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var achievement in Model)
                    {
                        <tr class="achievement-row"
                            data-title="@achievement.Title.ToLower()"
                            data-desc="@achievement.Description.ToLower()"
                            data-category="@achievement.Category"
                            data-rare="@(achievement.IsRare ? "rare" : "common")">

                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="achievement-icon @(achievement.IsRare ? "rare" : "")">
                                        <i class="fas fa-@(achievement.IsRare ? "medal" : "award")"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold" style="font-size:0.9rem;">
                                            @achievement.Title
                                            @if (achievement.IsRare)
                                            {
                                                <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">RARE</span>
                                            }
                                        </div>
                                        <div class="text-muted" style="font-size:0.78rem;">@achievement.Description</div>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <span class="badge rounded-pill" style="background:@GetCategoryColor(achievement.Category)20;color:@GetCategoryColor(achievement.Category);border:1px solid @GetCategoryColor(achievement.Category)40;">
                                    @achievement.Category
                                </span>
                            </td>

                            <td>
                                <span class="fw-semibold text-primary">@achievement.PointsRequired</span>
                                <span class="text-muted small ms-1">pts</span>
                            </td>

                            <td>
                                <span class="fw-semibold text-warning">+@achievement.PointsReward</span>
                                <span class="text-muted small ms-1">pts</span>
                            </td>

                            <td>
                                @if (achievement.IsRare)
                                {
                                    <span class="badge rounded-pill bg-warning-subtle text-warning">
                                        <i class="fas fa-gem me-1"></i>Rare
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary-subtle text-secondary">Common</span>
                                }
                            </td>

                            <td>
                                <span class="fw-bold text-success">@achievement.UserAchievements.Count</span>
                                <span class="text-muted small ms-1">users</span>
                            </td>

                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-area="Admin" asp-controller="Achievements" asp-action="Edit"
                                       asp-route-id="@achievement.Id"
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form asp-area="Admin" asp-controller="Achievements" asp-action="ToggleRare"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@achievement.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Toggle Rare">
                                            <i class="fas fa-gem"></i>
                                        </button>
                                    </form>

                                    <form asp-area="Admin" asp-controller="Achievements" asp-action="Delete"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@achievement.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                                onclick="return confirm('Delete this achievement? This cannot be undone.')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="emptyState" class="text-center py-5 d-none">
            <i class="fas fa-trophy text-muted" style="font-size:3rem;opacity:0.3;"></i>
            <p class="mt-3 text-muted">No achievements match your search.</p>
        </div>
    </div>
</div>

@functions {
    string GetCategoryColor(string category) => category switch
    {
        "Streak" => "#F59E0B",
        "Points" => "#4F46E5",
        "Completion" => "#10B981",
        "Accuracy" => "#EF4444",
        _ => "#6B7280"
    };
}

<style>
    .admin-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .admin-card-body {
        padding: 1.25rem;
    }

    .mini-stat-card {
        background: white;
        border-radius: 10px;
        border-left: 4px solid transparent;
        padding: 1rem 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .table > :not(caption) > * > * {
        padding: 0.85rem 0.75rem;
    }

    .achievement-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg,#6B7280,#9CA3AF);
        color: white;
        font-size: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .achievement-icon.rare {
            background: linear-gradient(135deg,#F59E0B,#D97706);
        }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const search   = document.getElementById('achievementSearch');
            const catFilter  = document.getElementById('categoryFilter');
            const rareFilter = document.getElementById('rareFilter');
            const rows     = document.querySelectorAll('.achievement-row');
            const empty    = document.getElementById('emptyState');

            function applyFilters() {
                const q    = search.value.toLowerCase();
                const cat  = catFilter.value;
                const rare = rareFilter.value;
                let visible = 0;

                rows.forEach(row => {
                    const textMatch = row.dataset.title.includes(q) || row.dataset.desc.includes(q);
                    const catMatch  = !cat  || row.dataset.category === cat;
                    const rareMatch = !rare || row.dataset.rare === rare;
                    const show = textMatch && catMatch && rareMatch;
                    row.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                empty.classList.toggle('d-none', visible > 0);
            }

            search.addEventListener('input', applyFilters);
            catFilter.addEventListener('change', applyFilters);
            rareFilter.addEventListener('change', applyFilters);
            document.getElementById('clearFilters').addEventListener('click', () => {
                search.value = ''; catFilter.value = ''; rareFilter.value = '';
                applyFilters();
            });
        });
    </script>
}