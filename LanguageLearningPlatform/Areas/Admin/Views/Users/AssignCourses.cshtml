@{
    var teacher = ViewBag.Teacher as LanguageLearningPlatform.Data.Models.User;
    var allCourses = ViewBag.AllCourses as List<LanguageLearningPlatform.Data.Models.Course>;
    var assignedIds = ViewBag.AssignedCourseIds as List<Guid> ?? new List<Guid>();
    ViewData["Title"] = "Assign Courses";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0"><i class="fas fa-book me-2"></i>Assign Courses</h1>
        <p class="text-muted small mb-0">@teacher?.FirstName @teacher?.LastName</p>
    </div>
    <a asp-action="Details" asp-route-id="@teacher?.Id" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="AssignCourses" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="teacherId" value="@teacher?.Id" />

            @if (allCourses == null || !allCourses.Any())
            {
                <p class="text-muted">No published courses available.</p>
            }
            else
            {
                <div class="row g-3 mb-4">
                    @foreach (var course in allCourses)
                    {
                        <div class="col-md-6">
                            <div class="form-check p-3 border rounded-3">
                                <input class="form-check-input" type="checkbox"
                                       name="courseIds" value="@course.Id"
                                       id="course_@course.Id"
                                       @(assignedIds.Contains(course.Id) ? "checked" : "") />
                                <label class="form-check-label fw-semibold" for="course_@course.Id">
                                    @course.Title
                                    <span class="badge bg-light text-dark ms-1">@course.Language</span>
                                    <span class="badge bg-secondary ms-1">@course.Level</span>
                                </label>
                            </div>
                        </div>
                    }
                </div>
            }

            <button type="submit" class="btn btn-primary px-4">
                <i class="fas fa-save me-2"></i>Save Assignments
            </button>
        </form>
    </div>
</div>