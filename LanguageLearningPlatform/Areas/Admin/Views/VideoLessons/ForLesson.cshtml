@model LanguageLearningPlatform.Data.Models.Course

@{
    ViewData["Title"] = "Lessons — " + Model.Title;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0" style="font-size:0.82rem;">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Courses" asp-action="Index">Courses</a>
                </li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0"><i class="fas fa-list me-2"></i>Lessons</h1>
        <p class="text-muted small mb-0">@Model.Language · @Model.Level</p>
    </div>
    <a asp-area="Admin" asp-controller="Courses" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Courses
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#4F46E5;">
            <div class="fw-bold" style="font-size:1.5rem;color:#4F46E5;">@Model.Lessons.Count</div>
            <div class="text-muted small">Total Lessons</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#EF4444;">
            <div class="fw-bold" style="font-size:1.5rem;color:#EF4444;">
                @Model.Lessons.Sum(l => l.VideoLessons.Count)
            </div>
            <div class="text-muted small">Total Videos</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#10B981;">
            <div class="fw-bold" style="font-size:1.5rem;color:#10B981;">
                @Model.Lessons.Sum(l => l.Exercises.Count)
            </div>
            <div class="text-muted small">Total Exercises</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="mini-stat-card" style="border-left-color:#F59E0B;">
            <div class="fw-bold" style="font-size:1.5rem;color:#F59E0B;">@Model.Level</div>
            <div class="text-muted small">Course Level</div>
        </div>
    </div>
</div>

@if (!Model.Lessons.Any())
{
    <div class="admin-card">
        <div class="admin-card-body text-center py-5">
            <i class="fas fa-list text-muted" style="font-size:3rem;opacity:0.3;"></i>
            <p class="mt-3 text-muted">No lessons found for this course.</p>
        </div>
    </div>
}
else
{
    <div class="admin-card">
        <div class="admin-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Lesson</th>
                            <th>Duration</th>
                            <th>Exercises</th>
                            <th>Videos</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lesson in Model.Lessons.OrderBy(l => l.OrderIndex))
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-semibold">@lesson.OrderIndex</td>
                                <td>
                                    <div class="fw-semibold" style="font-size:0.9rem;">@lesson.Title</div>
                                    @if (!string.IsNullOrEmpty(lesson.Description))
                                    {
                                        <div class="text-muted small text-truncate" style="max-width:280px;">
                                            @lesson.Description
                                        </div>
                                    }
                                </td>
                                <td><span class="text-muted small"><i class="fas fa-clock me-1"></i>@lesson.DurationMinutes min</span></td>
                                <td>
                                    <span class="badge bg-success-subtle text-success">
                                        <i class="fas fa-dumbbell me-1"></i>@lesson.Exercises.Count
                                    </span>
                                </td>
                                <td>
                                    @if (lesson.VideoLessons.Any())
                                    {
                                        <span class="badge bg-danger-subtle text-danger">
                                            <i class="fas fa-play me-1"></i>@lesson.VideoLessons.Count
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">
                                            <i class="fas fa-play me-1"></i>0
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (lesson.IsLocked)
                                    {
                                        <span class="badge rounded-pill bg-warning-subtle text-warning">
                                            <i class="fas fa-lock me-1"></i>Locked
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success">
                                            <i class="fas fa-unlock me-1"></i>Open
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-area="Admin"
                                       asp-controller="VideoLessons"
                                       asp-action="ForLesson"
                                       asp-route-lessonId="@lesson.Id"
                                       class="btn btn-sm btn-primary">
                                        <i class="fas fa-video me-1"></i>Manage Videos
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    .admin-card { background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); overflow: hidden; }
    .admin-card-body { padding: 1.25rem; }
    .mini-stat-card { background: white; border-radius: 10px; border-left: 4px solid transparent; padding: 1rem 1.25rem; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .table > :not(caption) > * > * { padding: 0.85rem 0.75rem; }
</style>