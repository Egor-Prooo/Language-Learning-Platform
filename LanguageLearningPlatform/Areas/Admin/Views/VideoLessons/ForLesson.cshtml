@model LanguageLearningPlatform.Data.Models.Lesson

@{
    ViewData["Title"] = "Videos — " + Model.Title;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0" style="font-size:0.82rem;">
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Courses" asp-action="Index">Courses</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-area="Admin" asp-controller="Lessons" asp-action="ForCourse"
                       asp-route-courseId="@Model.CourseId">@Model.Course.Title</a>
                </li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0"><i class="fas fa-video me-2"></i>Videos</h1>
        <p class="text-muted small mb-0">@Model.Course.Language · @Model.Course.Level · Lesson @Model.OrderIndex</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-area="Admin" asp-controller="Lessons" asp-action="ForCourse"
           asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Lessons
        </a>
        <a asp-area="Admin" asp-controller="VideoLessons" asp-action="Create"
           asp-route-lessonId="@Model.Id" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Video
        </a>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="mini-stat-card" style="border-left-color:#EF4444;">
            <div class="fw-bold" style="font-size:1.5rem;color:#EF4444;">
                @Model.VideoLessons.Count
            </div>
            <div class="text-muted small">Total Videos</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card" style="border-left-color:#10B981;">
            <div class="fw-bold" style="font-size:1.5rem;color:#10B981;">
                @Model.VideoLessons.Count(v => v.IsRequired)
            </div>
            <div class="text-muted small">Required</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="mini-stat-card" style="border-left-color:#4F46E5;">
            <div class="fw-bold" style="font-size:1.5rem;color:#4F46E5;">
                @(Model.VideoLessons.Sum(v => v.DurationSeconds) / 60) min
            </div>
            <div class="text-muted small">Total Duration</div>
        </div>
    </div>
</div>

@if (!Model.VideoLessons.Any())
{
    <div class="admin-card">
        <div class="admin-card-body text-center py-5">
            <i class="fas fa-video text-muted" style="font-size:3rem;opacity:0.3;"></i>
            <p class="mt-3 text-muted">No videos yet for this lesson.</p>
            <a asp-area="Admin" asp-controller="VideoLessons" asp-action="Create"
               asp-route-lessonId="@Model.Id" class="btn btn-primary mt-2">
                <i class="fas fa-plus me-2"></i>Add First Video
            </a>
        </div>
    </div>
}
else
{
    <div class="admin-card">
        <div class="admin-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Video</th>
                            <th>Provider</th>
                            <th>Duration</th>
                            <th>Required</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var video in Model.VideoLessons.OrderBy(v => v.OrderIndex))
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-semibold">@video.OrderIndex</td>
                                <td>
                                    <div class="fw-semibold" style="font-size:0.9rem;">@video.Title</div>
                                    @if (!string.IsNullOrEmpty(video.Description))
                                    {
                                        <div class="text-muted small text-truncate" style="max-width:300px;">
                                            @video.Description
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (video.VideoProvider == "YouTube")
                                    {
                                        <span class="badge bg-danger-subtle text-danger">
                                            <i class="fab fa-youtube me-1"></i>YouTube
                                        </span>
                                    }
                                    else if (video.VideoProvider == "Vimeo")
                                    {
                                        <span class="badge bg-info-subtle text-info">
                                            <i class="fab fa-vimeo me-1"></i>Vimeo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">
                                            <i class="fas fa-film me-1"></i>Direct
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (video.DurationSeconds > 0)
                                    {
                                        var minutes = video.DurationSeconds / 60;
                                        var seconds = video.DurationSeconds % 60;
                                        <span class="text-muted small">
                                            <i class="fas fa-clock me-1"></i>@minutes:@seconds.ToString("D2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    @if (video.IsRequired)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success">Required</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-secondary">Optional</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <form asp-area="Admin" asp-controller="VideoLessons"
                                          asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@video.Id" />
                                        <input type="hidden" name="lessonId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this video?')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    .admin-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .admin-card-body {
        padding: 1.25rem;
    }

    .mini-stat-card {
        background: white;
        border-radius: 10px;
        border-left: 4px solid transparent;
        padding: 1rem 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .table > :not(caption) > * > * {
        padding: 0.85rem 0.75rem;
    }
</style>