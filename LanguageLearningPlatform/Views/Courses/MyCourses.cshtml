@model IEnumerable<LanguageLearningPlatform.Data.Models.Course>

@{
    ViewData["Title"] = "My Courses";
    var progresses = ViewBag.Progresses as Dictionary<Guid, LanguageLearningPlatform.Data.Models.Progress>;
    var activeCourses = ViewBag.ActiveCourses as List<LanguageLearningPlatform.Data.Models.Course> ?? new();
    var completedCourses = ViewBag.CompletedCourses as List<LanguageLearningPlatform.Data.Models.Course> ?? new();
    var totalPoints = progresses?.Values.Sum(p => p.PointsEarned) ?? 0;
    var totalLessonsCompleted = progresses?.Values.Sum(p => p.CompletedLessons) ?? 0;
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800&family=Instrument+Serif:ital@0;1&display=swap');

        .mc-root {
            min-height: 100vh;
            background: #FAFAF8;
            font-family: 'Cabinet Grotesk', sans-serif;
            padding-bottom: 5rem;
        }

        /* ── Header ── */
        .mc-header {
            background: #1C1917;
            padding: 3rem 0 5rem;
            position: relative;
            overflow: hidden;
        }
        .mc-header::after {
            content: '';
            position: absolute;
            bottom: -1px; left: 0; right: 0;
            height: 60px;
            background: #FAFAF8;
            clip-path: ellipse(60% 100% at 50% 100%);
        }
        .mc-header-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: .12;
            pointer-events: none;
        }
        .mc-orb-1 { width:400px;height:400px;background:#F59E0B;top:-150px;right:-100px; }
        .mc-orb-2 { width:250px;height:250px;background:#10B981;bottom:0;left:-80px; }

        .mc-title {
            font-family: 'Instrument Serif', serif;
            font-size: 2.8rem;
            color: #FAFAF8;
            line-height: 1.1;
            margin-bottom: .5rem;
        }
        .mc-subtitle { color: rgba(255,255,255,.5); font-size: .95rem; }

        /* Stats row */
        .mc-stats {
            display: flex;
            gap: 2.5rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }
        .mc-stat-item { }
        .mc-stat-val {
            font-size: 2rem;
            font-weight: 800;
            color: #FAFAF8;
            line-height: 1;
        }
        .mc-stat-lbl {
            font-size: .72rem;
            color: rgba(255,255,255,.45);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-top: .2rem;
        }

        /* ── Tab Switcher ── */
        .mc-tabs {
            display: flex;
            gap: .5rem;
            padding: 1.75rem 0 0;
            position: relative;
            z-index: 2;
        }
        .mc-tab-btn {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .65rem 1.4rem;
            border-radius: 40px;
            border: 2px solid transparent;
            background: rgba(255,255,255,.08);
            color: rgba(255,255,255,.55);
            font-weight: 700;
            font-size: .85rem;
            cursor: pointer;
            transition: all .2s;
            font-family: 'Cabinet Grotesk', sans-serif;
        }
        .mc-tab-btn.active {
            background: #FAFAF8;
            color: #1C1917;
            border-color: #FAFAF8;
        }
        .mc-tab-btn:hover:not(.active) {
            background: rgba(255,255,255,.14);
            color: rgba(255,255,255,.85);
        }
        .mc-tab-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            font-size: .7rem;
            font-weight: 800;
            background: rgba(0,0,0,.15);
        }
        .mc-tab-btn.active .mc-tab-count { background: #1C1917; color: #FAFAF8; }

        /* ── Body ── */
        .mc-body { padding-top: 2.5rem; }

        /* ── Course Card ── */
        .mc-card {
            background: #fff;
            border-radius: 20px;
            border: 1.5px solid #E8E6E0;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s, border-color .2s;
            position: relative;
        }
        .mc-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(0,0,0,.1);
            border-color: #D1D0CC;
        }
        .mc-card.completed-card { border-color: #BBF7D0; background: linear-gradient(135deg, #F0FFF4, #fff); }
        .mc-card.completed-card:hover { border-color: #86EFAC; }

        .mc-card-stripe {
            height: 5px;
            background: linear-gradient(90deg, #4F46E5, #7C3AED);
        }
        .mc-card.completed-card .mc-card-stripe {
            background: linear-gradient(90deg, #10B981, #34D399);
        }

        .mc-card-body { padding: 1.5rem; }

        .mc-lang-icon {
            width: 48px; height: 48px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            color: white;
        }
        .completed-card .mc-lang-icon { background: linear-gradient(135deg, #10B981, #059669); }

        .mc-card-title {
            font-weight: 800;
            font-size: 1rem;
            color: #1C1917;
            line-height: 1.3;
            margin-bottom: .3rem;
        }
        .mc-card-meta {
            font-size: .75rem;
            color: #78716C;
            display: flex; gap: .75rem; flex-wrap: wrap;
        }

        /* Progress bar */
        .mc-bar-track {
            height: 7px;
            border-radius: 10px;
            background: #F3F4F6;
            overflow: hidden;
            margin: .85rem 0 .4rem;
        }
        .mc-bar-fill {
            height: 100%;
            border-radius: 10px;
            background: linear-gradient(90deg, #4F46E5, #7C3AED);
            transition: width .8s cubic-bezier(.4,0,.2,1);
        }
        .completed-card .mc-bar-fill { background: linear-gradient(90deg, #10B981, #34D399); }

        .mc-bar-pct {
            font-weight: 800;
            font-size: .82rem;
            color: #4F46E5;
        }
        .completed-card .mc-bar-pct { color: #059669; }

        /* Points badge */
        .mc-pts-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            background: #FEF3C7; color: #92400E;
            font-size: .72rem; font-weight: 700;
            padding: .2rem .6rem; border-radius: 20px;
            border: 1px solid #FCD34D;
        }

        /* Completed badge */
        .mc-done-badge {
            display: inline-flex; align-items: center; gap: .35rem;
            background: #D1FAE5; color: #065F46;
            font-size: .72rem; font-weight: 700;
            padding: .25rem .65rem; border-radius: 20px;
            border: 1px solid #6EE7B7;
        }

        /* Actions */
        .mc-actions {
            display: flex; gap: .5rem; margin-top: 1.1rem; flex-wrap: wrap;
        }

        .btn-mc-primary {
            flex: 1;
            padding: .65rem 1rem;
            background: #1C1917;
            color: #FAFAF8;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: .85rem;
            text-align: center;
            text-decoration: none;
            transition: all .2s;
            display: flex; align-items: center; justify-content: center; gap: .4rem;
            cursor: pointer;
            font-family: 'Cabinet Grotesk', sans-serif;
        }
        .btn-mc-primary:hover { background: #292524; color: #FAFAF8; transform: translateY(-1px); }
        .btn-mc-danger {
            padding: .65rem .9rem;
            background: transparent;
            color: #DC2626;
            border: 1.5px solid #FECACA;
            border-radius: 12px;
            font-weight: 700;
            font-size: .82rem;
            cursor: pointer;
            transition: all .2s;
            font-family: 'Cabinet Grotesk', sans-serif;
            white-space: nowrap;
        }
        .btn-mc-danger:hover { background: #FEF2F2; border-color: #FCA5A5; }
        .btn-mc-review {
            flex: 1;
            padding: .65rem 1rem;
            background: #F0FDF4;
            color: #065F46;
            border: 1.5px solid #BBF7D0;
            border-radius: 12px;
            font-weight: 700;
            font-size: .85rem;
            text-align: center;
            text-decoration: none;
            transition: all .2s;
            display: flex; align-items: center; justify-content: center; gap: .4rem;
        }
        .btn-mc-review:hover { background: #D1FAE5; color: #065F46; }

        /* ── Empty state ── */
        .mc-empty {
            text-align: center;
            padding: 4rem 2rem;
            background: white;
            border-radius: 20px;
            border: 2px dashed #E8E6E0;
        }
        .mc-empty-icon {
            font-size: 3.5rem;
            margin-bottom: 1rem;
            opacity: .25;
            color: #1C1917;
        }
        .mc-empty h4 { color: #57534E; margin-bottom: .5rem; font-weight: 700; }
        .mc-empty p { color: #A8A29E; font-size: .9rem; margin-bottom: 1.5rem; }

        /* Unenroll modal */
        .modal-content { border-radius: 20px; border: none; }
        .modal-header { border-bottom: 1px solid #F3F4F6; }
        .modal-footer { border-top: 1px solid #F3F4F6; }

        /* Tab panels */
        .mc-tab-panel { display: none; }
        .mc-tab-panel.active { display: block; }

        /* Bottom summary */
        .mc-summary {
            background: #1C1917;
            border-radius: 16px;
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 2.5rem;
        }
        .mc-summary-text { color: rgba(255,255,255,.7); font-size: .9rem; }
        .mc-summary-text strong { color: #FAFAF8; }

        @@media (max-width: 576px) {
            .mc-title { font-size: 2rem; }
            .mc-stats { gap: 1.5rem; }
        }
    </style>
}

<div class="mc-root">

    <!-- ── HEADER ── -->
    <div class="mc-header">
        <div class="mc-header-orb mc-orb-1"></div>
        <div class="mc-header-orb mc-orb-2"></div>
        <div class="container">
            <div class="row align-items-end">
                <div class="col-lg-7">
                    <div class="mc-title">
                        My Learning<br><em>Journey</em>
                    </div>
                    <div class="mc-subtitle">Pick up where you left off</div>
                    <div class="mc-stats">
                        <div class="mc-stat-item">
                            <div class="mc-stat-val">@activeCourses.Count</div>
                            <div class="mc-stat-lbl">Active</div>
                        </div>
                        <div class="mc-stat-item">
                            <div class="mc-stat-val">@completedCourses.Count</div>
                            <div class="mc-stat-lbl">Completed</div>
                        </div>
                        <div class="mc-stat-item">
                            <div class="mc-stat-val">@totalPoints.ToString("N0")</div>
                            <div class="mc-stat-lbl">Points</div>
                        </div>
                        <div class="mc-stat-item">
                            <div class="mc-stat-val">@totalLessonsCompleted</div>
                            <div class="mc-stat-lbl">Lessons Done</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab buttons inside header -->
            <div class="mc-tabs">
                <button class="mc-tab-btn active" onclick="switchTab('active', this)">
                    <i class="fas fa-bolt"></i>
                    Active
                    <span class="mc-tab-count">@activeCourses.Count</span>
                </button>
                <button class="mc-tab-btn" onclick="switchTab('completed', this)">
                    <i class="fas fa-check-circle"></i>
                    Completed
                    <span class="mc-tab-count">@completedCourses.Count</span>
                </button>
            </div>
        </div>
    </div>

    <!-- ── BODY ── -->
    <div class="container mc-body">

        <!-- Active Courses Panel -->
        <div class="mc-tab-panel active" id="panel-active">
            @if (!activeCourses.Any())
            {
                <div class="mc-empty">
                    <div class="mc-empty-icon"><i class="fas fa-compass"></i></div>
                    <h4>No active courses</h4>
                    <p>Browse the catalog and start learning something new today.</p>
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-dark px-4 py-2 rounded-pill fw-bold">
                        <i class="fas fa-search me-2"></i>Explore Courses
                    </a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var course in activeCourses)
                    {
                        var progress = progresses?.ContainsKey(course.Id) == true ? progresses[course.Id] : null;
                        var pct = progress?.CompletionPercentage ?? 0;
                        var pts = progress?.PointsEarned ?? 0;
                        var lessonsD = progress?.CompletedLessons ?? 0;

                        <div class="col-md-6 col-lg-4">
                            <div class="mc-card">
                                <div class="mc-card-stripe"></div>
                                <div class="mc-card-body">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="mc-lang-icon">
                                            @switch (course.Language.ToLower())
                                            {
                                                case "spanish":
                                                    <i class="fas fa-language"></i>
                                                    break;
                                                case "french":

                                                    <i class="fas fa-flag"></i>
                                                    break;
                                                case "german":

                                                    <i class="fas fa-book"></i>
                                                    break;
                                                case "japanese":

                                                    <i class="fas fa-yen-sign"></i>
                                                    break;
                                                default:

                                                    <i class="fas fa-globe"></i>
                                                    break;
                                            }
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="mc-card-title text-truncate">@course.Title</div>
                                            <div class="mc-card-meta">
                                                <span><i class="fas fa-globe me-1"></i>@course.Language</span>
                                                <span class="badge rounded-pill" style="background:#F3F4F6;color:#57534E;font-size:.68rem;">@course.Level</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Progress -->
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted" style="font-size:.75rem;font-weight:600;">
                                            @lessonsD / @course.Lessons.Count lessons
                                        </span>
                                        <span class="mc-bar-pct">@pct.ToString("F0")%</span>
                                    </div>
                                    <div class="mc-bar-track">
                                        <div class="mc-bar-fill" style="width:@pct%"></div>
                                    </div>

                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        @if (pts > 0)
                                        {
                                            <span class="mc-pts-badge">
                                                <i class="fas fa-star"></i>@pts pts
                                            </span>
                                        }
                                        @if (progress?.LastAccessedAt != null)
                                        {
                                            <span style="font-size:.72rem;color:#A8A29E;">
                                                Last active @progress.LastAccessedAt.ToString("MMM dd")
                                            </span>
                                        }
                                    </div>

                                    <div class="mc-actions">
                                        @{
                                            var firstLesson = course.Lessons.OrderBy(l => l.OrderIndex).FirstOrDefault();
                                        }
                                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id"
                                           class="btn-mc-primary">
                                            <i class="fas fa-play"></i>
                                            @(pct > 0 ? "Continue" : "Start Learning")
                                        </a>
                                        <button class="btn-mc-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#unenrollModal"
                                                data-course-id="@course.Id"
                                                data-course-name="@course.Title">
                                            <i class="fas fa-door-open me-1"></i>Leave
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Explore more -->
                <div class="text-center mt-4">
                    <a asp-controller="Courses" asp-action="Index"
                       style="color:#78716C;font-size:.85rem;font-weight:600;text-decoration:none;">
                        <i class="fas fa-plus me-1"></i>Find more courses
                    </a>
                </div>
            }
        </div>

        <!-- Completed Courses Panel -->
        <div class="mc-tab-panel" id="panel-completed">
            @if (!completedCourses.Any())
            {
                <div class="mc-empty">
                    <div class="mc-empty-icon"><i class="fas fa-trophy"></i></div>
                    <h4>No completed courses yet</h4>
                    <p>Finish your active courses to see them here.</p>
                    @if (activeCourses.Any())
                    {
                        <button class="btn btn-dark px-4 py-2 rounded-pill fw-bold"
                                onclick="switchTab('active', document.querySelector('.mc-tab-btn'))">
                            <i class="fas fa-arrow-left me-2"></i>Back to Active
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var course in completedCourses)
                    {
                        var progress = progresses?.ContainsKey(course.Id) == true ? progresses[course.Id] : null;
                        var pts = progress?.PointsEarned ?? 0;
                        var completedOn = progress?.CompletedAt?.ToString("MMM dd, yyyy") ?? "Recently";

                        <div class="col-md-6 col-lg-4">
                            <div class="mc-card completed-card">
                                <div class="mc-card-stripe"></div>
                                <div class="mc-card-body">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <div class="mc-lang-icon">
                                            @switch (course.Language.ToLower())
                                            {
                                                case "spanish":
                                                    <i class="fas fa-language"></i>
                                                    break;
                                                case "french":

                                                    <i class="fas fa-flag"></i>
                                                    break;
                                                case "german":

                                                    <i class="fas fa-book"></i>
                                                    break;
                                                case "japanese":

                                                    <i class="fas fa-yen-sign"></i>
                                                    break;
                                                default:

                                                    <i class="fas fa-globe"></i>
                                                    break;
                                            }
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="mc-card-title text-truncate">@course.Title</div>
                                            <div class="mc-card-meta">
                                                <span><i class="fas fa-globe me-1"></i>@course.Language</span>
                                                <span class="badge rounded-pill" style="background:#F0FDF4;color:#065F46;font-size:.68rem;">@course.Level</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Full bar -->
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted" style="font-size:.75rem;font-weight:600;">
                                            @course.Lessons.Count / @course.Lessons.Count lessons
                                        </span>
                                        <span class="mc-bar-pct">100%</span>
                                    </div>
                                    <div class="mc-bar-track">
                                        <div class="mc-bar-fill" style="width:100%"></div>
                                    </div>

                                    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                        <span class="mc-done-badge">
                                            <i class="fas fa-check-circle"></i>Completed @completedOn
                                        </span>
                                        @if (pts > 0)
                                        {
                                            <span class="mc-pts-badge">
                                                <i class="fas fa-star"></i>@pts pts earned
                                            </span>
                                        }
                                    </div>

                                    <div class="mc-actions">
                                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id"
                                           class="btn-mc-review">
                                            <i class="fas fa-eye"></i>Review Course
                                        </a>
                                        <button class="btn-mc-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#unenrollModal"
                                                data-course-id="@course.Id"
                                                data-course-name="@course.Title">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Summary bar -->
        @if (Model.Any())
        {
            <div class="mc-summary">
                <div class="mc-summary-text">
                    <strong>@(activeCourses.Count + completedCourses.Count) courses</strong> total &nbsp;·&nbsp;
                    <strong>@totalLessonsCompleted</strong> lessons completed &nbsp;·&nbsp;
                    <strong>@totalPoints.ToString("N0")</strong> points earned
                </div>
                <a asp-controller="Courses" asp-action="Index"
                   class="btn btn-sm"
                   style="background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);border-radius:10px;font-weight:700;font-size:.8rem;border:1px solid rgba(255,255,255,.2);">
                    <i class="fas fa-compass me-1"></i>Explore More
                </a>
            </div>
        }
    </div>
</div>

<!-- ── Unenroll Confirmation Modal ── -->
<div class="modal fade" id="unenrollModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-door-open me-2 text-warning"></i>Leave Course?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2 pb-3">
                <p class="text-secondary mb-2">
                    You're about to leave <strong id="unenroll-course-name"></strong>.
                </p>
                <div class="alert alert-info py-2 mb-0" style="border-radius:12px;font-size:.875rem;">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Your progress is saved.</strong> If you re-enroll later, you'll continue from where you left off.
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">
                    Stay Enrolled
                </button>
                <form id="unenroll-form" asp-controller="Courses" asp-action="Unenroll" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="unenroll-course-id" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold">
                        <i class="fas fa-door-open me-2"></i>Leave Course
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Tab switching ──
        function switchTab(tabName, btn) {
            document.querySelectorAll('.mc-tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.mc-tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('panel-' + tabName).classList.add('active');
            if (btn) btn.classList.add('active');
        }

        // ── Progress bar animation ──
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.mc-bar-fill').forEach(bar => {
                const w = bar.style.width;
                bar.style.width = '0';
                setTimeout(() => { bar.style.width = w; }, 150);
            });

            // ── Unenroll modal population ──
            const unenrollModal = document.getElementById('unenrollModal');
            unenrollModal?.addEventListener('show.bs.modal', e => {
                const btn = e.relatedTarget;
                document.getElementById('unenroll-course-id').value = btn.dataset.courseId;
                document.getElementById('unenroll-course-name').textContent = btn.dataset.courseName;
            });

            // ── Auto-switch to completed tab if URL has #completed ──
            if (window.location.hash === '#completed') {
                const btn = document.querySelectorAll('.mc-tab-btn')[1];
                switchTab('completed', btn);
            }
        });
    </script>
}
