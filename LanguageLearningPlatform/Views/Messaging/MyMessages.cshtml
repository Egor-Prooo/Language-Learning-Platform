@using LanguageLearningPlatform.Web.Controllers
@model IEnumerable<StudentConversationViewModel>

@{
    ViewData["Title"] = "My Messages";
}

<div class="container my-5">
    <h1 class="fw-bold mb-4"><i class="fas fa-inbox me-2 text-primary"></i>My Messages</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded-4" style="border-style:dashed!important;">
            <i class="fas fa-envelope-open" style="font-size:4rem;color:#D1D5DB;"></i>
            <h4 class="mt-3 text-secondary">No messages yet</h4>
            <p class="text-secondary">Contact a teacher from a course page to start a conversation.</p>
            <a asp-controller="Courses" asp-action="MyCourses" class="btn btn-primary">
                <i class="fas fa-book me-2"></i>My Courses
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var conv in Model)
            {
                <div class="card shadow-sm" style="border-radius:16px;border:2px solid @(conv.HasUnreadReplies ? "#4F46E5" : "#E5E7EB");">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width:48px;height:48px;background:linear-gradient(135deg,#4F46E5,#7C3AED);">
                                    @(conv.TeacherName.Length > 0 ? conv.TeacherName[0].ToString().ToUpper() : "T")
                                </div>
                                <div>
                                    <div class="fw-bold">
                                        @conv.TeacherName
                                        <span class="badge bg-primary ms-1" style="font-size:0.7rem;">Teacher</span>
                                    </div>
                                    <div class="text-secondary small"><i class="fas fa-book me-1"></i>@conv.CourseName</div>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="text-secondary small">@conv.LastMessageAt.ToString("MMM dd, HH:mm")</div>
                                @if (conv.HasUnreadReplies)
                                {
                                    <span class="badge bg-primary mt-1">New reply</span>
                                }
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-2 mb-3" style="max-height:250px;overflow-y:auto;">
                            @foreach (var msg in conv.Messages)
                            {
                                <div class="d-flex @(msg.IsFromTeacher ? "justify-content-start" : "justify-content-end")">
                                    <div class="p-3 rounded-3" style="max-width:75%;background:@(msg.IsFromTeacher ? "#EEF2FF" : "#F9FAFB");border:1px solid @(msg.IsFromTeacher ? "#C7D2FE" : "#E5E7EB");">
                                        <div class="small text-secondary mb-1">
                                            @(msg.IsFromTeacher? conv.TeacherName + " (Teacher)" : "You") · @msg.SentAt.ToString("MMM dd, HH:mm")
                                        </div>
                                        <div>@msg.Message</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <a asp-controller="Messaging" asp-action="ContactTeacher" asp-route-courseId="@conv.CourseId"
                           class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-reply me-1"></i>Reply
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>