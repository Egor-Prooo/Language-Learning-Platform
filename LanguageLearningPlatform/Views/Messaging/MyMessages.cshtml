@using LanguageLearningPlatform.Web.Controllers
@model IEnumerable<StudentConversationViewModel>

@{
    ViewData["Title"] = "My Messages";
    var available = ViewBag.AvailableCourses as List<AvailableCourseForMessaging> ?? new();
}

<div class="container my-5">

    <div class="row g-4">

        <!-- ── LEFT: active conversations ── -->
        <div class="col-lg-8">

            <h1 class="fw-bold mb-1">
                <i class="fas fa-inbox me-2 text-primary"></i>My Messages
            </h1>
            <p class="text-secondary mb-4">Conversations with your course teachers</p>

            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded-4" style="border-style:dashed!important;">
                    <i class="fas fa-comments" style="font-size:3.5rem;color:#D1D5DB;"></i>
                    <h4 class="mt-3 text-secondary">No conversations yet</h4>
                    <p class="text-secondary mb-0">Pick a course on the right to message its teacher.</p>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var conv in Model)
                    {
                        <div class="card shadow-sm"
                             style="border-radius:16px;border:2px solid @(conv.HasUnreadReplies ? "#4F46E5" : "#E5E7EB");">
                            <div class="card-body p-4">

                                <!-- Conversation header -->
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                             style="width:48px;height:48px;background:linear-gradient(135deg,#4F46E5,#7C3AED);font-size:1rem;">
                                            @string.Concat(conv.TeacherName.Split(' ').Take(2).Select(p => p[0]))
                                        </div>
                                        <div>
                                            <div class="fw-bold">
                                                @conv.TeacherName
                                                <span class="badge bg-primary ms-1" style="font-size:0.7rem;">Teacher</span>
                                                @if (conv.HasUnreadReplies)
                                                {
                                                    <span class="badge ms-1" style="background:#4F46E5;font-size:0.7rem;">New reply</span>
                                                }
                                            </div>
                                            <div class="text-secondary small">
                                                <i class="fas fa-book me-1"></i>@conv.CourseName
                                                @if (!string.IsNullOrEmpty(conv.CourseLanguage))
                                                {
                                                    <span class="ms-2 badge bg-light text-dark" style="font-size:0.7rem;">@conv.CourseLanguage</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-secondary small">@conv.LastMessageAt.ToString("MMM dd, HH:mm")</div>
                                </div>

                                <!-- Message thread (collapsed, last 3) -->
                                <div class="d-flex flex-column gap-2 mb-3"
                                     style="max-height:220px;overflow-y:auto;">
                                    @foreach (var msg in conv.Messages.TakeLast(10))
                                    {
                                        <div class="d-flex @(msg.IsFromTeacher ? "justify-content-start" : "justify-content-end")">
                                            <div class="p-3 rounded-3"
                                                 style="max-width:78%;
                                                                    background:@(msg.IsFromTeacher ? "#EEF2FF" : "#F9FAFB");
                                                                    border:1px solid @(msg.IsFromTeacher ? "#C7D2FE" : "#E5E7EB");">
                                                <div class="small text-secondary mb-1">
                                                    @(msg.IsFromTeacher ? $"{conv.TeacherName} (Teacher)" : "You")
                                                    · @msg.SentAt.ToString("MMM dd, HH:mm")
                                                </div>
                                                <div>@msg.Message</div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <!-- Inline reply box -->
                                <form asp-action="SendMessage" method="post" class="d-flex gap-2 align-items-end">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@conv.CourseId" />
                                    <textarea name="message" class="form-control" rows="2"
                                      placeholder="Write a reply…" required
                                      style="resize:none;border-radius:12px;"></textarea>
                                    <button type="submit" class="btn btn-primary px-3 flex-shrink-0"
                                            style="border-radius:12px;height:fit-content;">
                                        <i class="fas fa-paper-plane"></i>
                                    </button>
                                </form>

                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ── RIGHT: start a new conversation ── -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top:1.5rem;">

                <h5 class="fw-bold mb-3">
                    <i class="fas fa-plus-circle me-2 text-primary"></i>Message a Teacher
                </h5>

                @if (!available.Any())
                {
                    <div class="p-4 border rounded-4 text-center text-secondary" style="border-style:dashed!important;">
                        <i class="fas fa-check-circle d-block mb-2" style="font-size:2rem;color:#10B981;"></i>
                        You have an active conversation for every enrolled course.
                    </div>
                }
                else
                {
                    <p class="text-secondary small mb-3">
                        Select a course below to start a new conversation with its teacher.
                    </p>

                    <div class="d-flex flex-column gap-2">
                        @foreach (var course in available)
                        {
                            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                             style="width:42px;height:42px;background:linear-gradient(135deg,#F0F0FF,#E0E7FF);">
                                            <i class="fas fa-book" style="color:#4F46E5;font-size:1rem;"></i>
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="fw-semibold text-truncate" style="font-size:0.9rem;">@course.CourseName</div>
                                            <div class="text-secondary" style="font-size:0.78rem;">
                                                <i class="fas fa-user me-1"></i>@course.TeacherName
                                            </div>
                                            <div class="mt-1">
                                                <span class="badge bg-light text-dark" style="font-size:0.7rem;">@course.CourseLanguage</span>
                                                <span class="badge bg-light text-dark ms-1" style="font-size:0.7rem;">@course.CourseLevel</span>
                                            </div>
                                        </div>
                                        <a asp-action="ContactTeacher"
                                           asp-route-courseId="@course.CourseId"
                                           class="btn btn-sm btn-primary flex-shrink-0"
                                           style="border-radius:10px;">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <hr class="my-4" />

                <a asp-controller="Courses" asp-action="MyCourses" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-book me-2"></i>My Courses
                </a>
            </div>
        </div>

    </div>
</div>