@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap');

        .err-root {
            min-height: calc(100vh - 200px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 1rem;
            background: #0D0D12;
            font-family: 'Space Grotesk', sans-serif;
            position: relative;
            overflow: hidden;
        }

        /* Grid overlay */
        .err-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(99,102,241,.06) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,.06) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        /* Glow orbs */
        .err-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
        }

        .err-orb-1 {
            width: 400px;
            height: 400px;
            background: #4F46E5;
            opacity: .12;
            top: -100px;
            left: -100px;
        }

        .err-orb-2 {
            width: 300px;
            height: 300px;
            background: #EF4444;
            opacity: .1;
            bottom: -50px;
            right: -80px;
        }

        .err-content {
            text-align: center;
            position: relative;
            z-index: 2;
            max-width: 580px;
        }

        /* Big 404 */
        .err-code {
            font-family: 'Space Mono', monospace;
            font-size: clamp(6rem, 18vw, 10rem);
            font-weight: 700;
            line-height: 1;
            letter-spacing: -4px;
            color: transparent;
            background: linear-gradient(135deg, #4F46E5 0%, #818CF8 50%, #4F46E5 100%);
            background-clip: text;
            -webkit-background-clip: text;
            margin-bottom: 0;
            user-select: none;
            filter: drop-shadow(0 0 40px rgba(79,70,229,.4));
        }

        .err-slash {
            font-family: 'Space Mono', monospace;
            font-size: clamp(6rem, 18vw, 10rem);
            color: #EF4444;
            opacity: .6;
            line-height: 1;
            letter-spacing: -4px;
            display: inline;
            filter: drop-shadow(0 0 30px rgba(239,68,68,.3));
        }

        .err-badge {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            background: rgba(239,68,68,.12);
            border: 1px solid rgba(239,68,68,.25);
            color: #F87171;
            font-size: .72rem;
            font-weight: 700;
            padding: .35rem .9rem;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: .1em;
            font-family: 'Space Mono', monospace;
            margin-bottom: 1.5rem;
            margin-top: 1rem;
        }

        .err-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #F1F5F9;
            margin-bottom: .75rem;
            line-height: 1.3;
        }

        .err-desc {
            color: #64748B;
            font-size: .95rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .err-path {
            display: inline-block;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 8px;
            padding: .5rem 1rem;
            font-family: 'Space Mono', monospace;
            font-size: .78rem;
            color: #94A3B8;
            margin-bottom: 2rem;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .err-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-err-primary {
            padding: .85rem 2rem;
            background: #4F46E5;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: .9rem;
            text-decoration: none;
            transition: all .2s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
        }

            .btn-err-primary:hover {
                background: #4338CA;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(79,70,229,.4);
            }

        .btn-err-secondary {
            padding: .85rem 2rem;
            background: transparent;
            color: #94A3B8;
            border: 1.5px solid #1E293B;
            border-radius: 12px;
            font-weight: 700;
            font-size: .9rem;
            text-decoration: none;
            transition: all .2s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
        }

            .btn-err-secondary:hover {
                border-color: #334155;
                color: #CBD5E1;
            }

        /* Animated dots */
        .err-dots {
            display: flex;
            justify-content: center;
            gap: .5rem;
            margin: 2rem 0 0;
        }

        .err-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #334155;
            animation: dotPulse 1.4s ease-in-out infinite;
        }

            .err-dot:nth-child(2) {
                animation-delay: .2s;
            }

            .err-dot:nth-child(3) {
                animation-delay: .4s;
            }

        @@keyframes dotPulse {
            0%, 100% {
                background: #334155;
                transform: scale(1);
            }

            50% {
                background: #4F46E5;
                transform: scale(1.4);
            }
        }
    </style>
}

<div class="err-root">
    <div class="err-grid"></div>
    <div class="err-orb err-orb-1"></div>
    <div class="err-orb err-orb-2"></div>

    <div class="err-content">
        <div>
            <span class="err-code">4</span><span class="err-slash">0</span><span class="err-code">4</span>
        </div>

        <div class="err-badge">
            <i class="fas fa-map-marker-slash"></i>Page Not Found
        </div>

        <h1 class="err-title">This page wandered off</h1>
        <p class="err-desc">
            The page you're looking for doesn't exist, has been moved, or was deleted.
            It might also be a typo in the URL.
        </p>

        @if (!string.IsNullOrEmpty(ViewBag.OriginalPath as string))
        {
            <div class="err-path">@ViewBag.OriginalPath</div>
        }

        <div class="err-actions">
            <a href="/" class="btn-err-primary">
                <i class="fas fa-home"></i>Go Home
            </a>
            <a asp-controller="Courses" asp-action="Index" class="btn-err-secondary">
                <i class="fas fa-compass"></i>Browse Courses
            </a>
        </div>

        <div class="err-dots">
            <div class="err-dot"></div>
            <div class="err-dot"></div>
            <div class="err-dot"></div>
        </div>
    </div>
</div>