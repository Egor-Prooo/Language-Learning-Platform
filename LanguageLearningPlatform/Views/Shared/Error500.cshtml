@{
    ViewData["Title"] = "Something went wrong";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap');

        .err-root {
            min-height: calc(100vh - 200px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 1rem;
            background: #0D0D12;
            font-family: 'Space Grotesk', sans-serif;
            position: relative;
            overflow: hidden;
        }

        .err-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(239,68,68,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(239,68,68,.05) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }

        .err-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
        }

        .err-orb-1 {
            width: 400px;
            height: 400px;
            background: #EF4444;
            opacity: .1;
            top: -100px;
            left: 50%;
            transform: translateX(-50%);
        }

        .err-orb-2 {
            width: 200px;
            height: 200px;
            background: #8B5CF6;
            opacity: .08;
            bottom: -60px;
            right: -60px;
        }

        .err-content {
            text-align: center;
            position: relative;
            z-index: 2;
            max-width: 580px;
        }

        /* Glitchy 500 */
        .err-code-wrap {
            position: relative;
            display: inline-block;
            margin-bottom: .5rem;
        }

        .err-code {
            font-family: 'Space Mono', monospace;
            font-size: clamp(5rem, 16vw, 9rem);
            font-weight: 700;
            line-height: 1;
            letter-spacing: -4px;
            color: #EF4444;
            user-select: none;
            filter: drop-shadow(0 0 40px rgba(239,68,68,.4));
            position: relative;
        }

            .err-code::before {
                content: '500';
                position: absolute;
                left: 3px;
                top: 3px;
                color: #8B5CF6;
                opacity: .4;
                clip-path: polygon(0 30%, 100% 30%, 100% 55%, 0 55%);
                animation: glitch 3.5s infinite;
            }

            .err-code::after {
                content: '500';
                position: absolute;
                left: -3px;
                top: -2px;
                color: #06B6D4;
                opacity: .3;
                clip-path: polygon(0 65%, 100% 65%, 100% 80%, 0 80%);
                animation: glitch 3.5s .15s infinite;
            }

        @@keyframes glitch {
            0%, 90%, 100% {
                transform: translateX(0);
            }

            92% {
                transform: translateX(-4px);
            }

            94% {
                transform: translateX(4px);
            }

            96% {
                transform: translateX(-2px);
            }
        }

        .err-badge {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            background: rgba(239,68,68,.1);
            border: 1px solid rgba(239,68,68,.25);
            color: #F87171;
            font-size: .72rem;
            font-weight: 700;
            padding: .35rem .9rem;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: .1em;
            font-family: 'Space Mono', monospace;
            margin-bottom: 1.5rem;
        }

        .err-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #F1F5F9;
            margin-bottom: .75rem;
            line-height: 1.3;
        }

        .err-desc {
            color: #64748B;
            font-size: .95rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .err-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-err-primary {
            padding: .85rem 2rem;
            background: #EF4444;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: .9rem;
            text-decoration: none;
            transition: all .2s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
        }

            .btn-err-primary:hover {
                background: #DC2626;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(239,68,68,.4);
            }

        .btn-err-secondary {
            padding: .85rem 2rem;
            background: transparent;
            color: #94A3B8;
            border: 1.5px solid #1E293B;
            border-radius: 12px;
            font-weight: 700;
            font-size: .9rem;
            text-decoration: none;
            transition: all .2s;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
        }

            .btn-err-secondary:hover {
                border-color: #334155;
                color: #CBD5E1;
            }

        /* Terminal-style error info */
        .err-terminal {
            background: #0A0A0F;
            border: 1px solid #1E293B;
            border-radius: 14px;
            padding: 1.25rem 1.5rem;
            font-family: 'Space Mono', monospace;
            font-size: .75rem;
            color: #64748B;
            text-align: left;
            margin-bottom: 2rem;
            line-height: 1.8;
        }

            .err-terminal .t-line {
                display: flex;
                gap: .75rem;
            }

            .err-terminal .t-prompt {
                color: #EF4444;
                flex-shrink: 0;
            }

            .err-terminal .t-text {
                color: #94A3B8;
            }

            .err-terminal .t-cursor {
                display: inline-block;
                width: 8px;
                height: .9em;
                background: #EF4444;
                margin-left: 3px;
                animation: blink 1s step-end infinite;
                vertical-align: middle;
            }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0;
            }
        }
    </style>
}

<div class="err-root">
    <div class="err-grid"></div>
    <div class="err-orb err-orb-1"></div>
    <div class="err-orb err-orb-2"></div>

    <div class="err-content">
        <div class="err-code-wrap">
            <div class="err-code">500</div>
        </div>

        <div class="err-badge">
            <i class="fas fa-exclamation-triangle"></i>Internal Server Error
        </div>

        <h1 class="err-title">Something broke on our end</h1>
        <p class="err-desc">
            Our server ran into an unexpected problem. This is not your fault —
            our team has been notified. Please try again in a moment.
        </p>

        <div class="err-terminal">
            <div class="t-line">
                <span class="t-prompt">$</span>
                <span class="t-text">ping lingolearn.app</span>
            </div>
            <div class="t-line">
                <span class="t-prompt">!</span>
                <span class="t-text" style="color:#EF4444;">ECONNRESET — server encountered an internal error</span>
            </div>
            <div class="t-line">
                <span class="t-prompt">$</span>
                <span class="t-text">_ <span class="t-cursor"></span></span>
            </div>
        </div>

        <div class="err-actions">
            <a href="javascript:history.back()" class="btn-err-primary">
                <i class="fas fa-undo"></i>Go Back
            </a>
            <a href="/" class="btn-err-secondary">
                <i class="fas fa-home"></i>Go Home
            </a>
        </div>
    </div>
</div>
