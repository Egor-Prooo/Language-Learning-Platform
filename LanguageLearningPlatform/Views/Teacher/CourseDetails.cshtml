@model LanguageLearningPlatform.Data.Models.Course

@{
    ViewData["Title"] = "Manage Course";
    var progresses = ViewBag.Progresses as Dictionary<string, LanguageLearningPlatform.Data.Models.Progress>;
}

<div class="container my-5">

    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active">@Model.Title</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">

            <div class="card shadow-sm mb-4" style="border-radius:16px;border:none;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge @(Model.IsPublished ? "bg-success" : "bg-secondary")">
                                    @(Model.IsPublished ? "Published" : "Draft")
                                </span>
                                <span class="badge bg-light text-dark">@Model.Level</span>
                                <span class="badge bg-light text-dark">@Model.Language</span>
                            </div>
                            <h2 class="fw-bold mb-1">@Model.Title</h2>
                            <p class="text-secondary">@Model.Description</p>
                        </div>
                        <form asp-action="TogglePublish" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn @(Model.IsPublished ? "btn-outline-warning" : "btn-success")">
                                <i class="fas fa-@(Model.IsPublished ? "eye-slash" : "globe") me-1"></i>
                                @(Model.IsPublished ? "Unpublish" : "Publish")
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4" style="border-radius:16px;border:none;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0"><i class="fas fa-list me-2 text-primary"></i>Lessons (@Model.Lessons.Count)</h5>
                        <a asp-action="AddLesson" asp-route-courseId="@Model.Id" class="btn btn-sm btn-primary">
                            <i class="fas fa-plus me-1"></i>Add Lesson
                        </a>
                    </div>

                    @if (!Model.Lessons.Any())
                    {
                        <p class="text-secondary text-center py-3">No lessons yet. Add your first lesson!</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var lesson in Model.Lessons)
                            {
                                <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:#F9FAFB;border:1px solid #E5E7EB;">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-primary flex-shrink-0"
                                         style="width:36px;height:36px;background:white;border:2px solid #4F46E5;font-size:0.85rem;">
                                        @lesson.OrderIndex
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold">@lesson.Title</div>
                                        <div class="text-secondary small">
                                            @lesson.DurationMinutes min &nbsp;·&nbsp; @lesson.Exercises.Count exercises
                                        </div>
                                    </div>
                                    <a asp-controller="Lessons" asp-action="Details" asp-route-id="@lesson.Id"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="ManageExercises" asp-route-lessonId="@lesson.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-dumbbell me-1"></i>Exercises (@lesson.Exercises.Count)
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm" style="border-radius:16px;border:none;position:sticky;top:1rem;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-users me-2 text-primary"></i>Enrolled Students (@Model.Enrollments.Count)
                    </h5>
                    @if (!Model.Enrollments.Any())
                    {
                        <p class="text-secondary small">No students enrolled yet.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2" style="max-height:400px;overflow-y:auto;">
                            @foreach (var enrollment in Model.Enrollments.Where(e => e.IsActive))
                            {
                                var progress = progresses?.ContainsKey(enrollment.UserId) == true ? progresses[enrollment.UserId] : null;
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#F9FAFB;">
                                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                                         style="width:36px;height:36px;font-size:0.8rem;">
                                        @(enrollment.User?.FirstName?.Substring(0, 1))@(enrollment.User?.LastName?.Substring(0, 1))
                                    </div>
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="small fw-semibold text-truncate">
                                            @enrollment.User?.FirstName @enrollment.User?.LastName
                                        </div>
                                        @if (progress != null)
                                        {
                                            <div class="progress mt-1" style="height:4px;">
                                                <div class="progress-bar bg-primary" style="width:@progress.CompletionPercentage%"></div>
                                            </div>
                                            <div class="text-secondary" style="font-size:0.7rem;">@progress.CompletionPercentage.ToString("F0")% complete</div>
                                        }
                                    </div>
                                    <a asp-action="StudentProgress" asp-route-studentId="@enrollment.UserId"
                                       class="btn btn-outline-secondary" style="font-size:0.7rem;padding:0.2rem 0.5rem;">
                                        View
                                    </a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>