@{
    ViewData["Title"] = "Create New Course";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="d-flex align-items-center gap-3 mb-4">
                <a asp-action="Dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Dashboard
                </a>
                <h2 class="fw-bold mb-0">Create New Course</h2>
            </div>

            <div class="card shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-body p-4">
                    <form asp-action="CreateCourse" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Course Title *</label>
                            <input type="text" name="title" class="form-control" placeholder="e.g. Spanish for Beginners" required maxlength="200" />
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Language *</label>
                                <select name="language" class="form-select" required>
                                    <option value="">Select language...</option>
                                    <option>Spanish</option>
                                    <option>French</option>
                                    <option>German</option>
                                    <option>Japanese</option>
                                    <option>Italian</option>
                                    <option>Chinese</option>
                                    <option>Portuguese</option>
                                    <option>Russian</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Level *</label>
                                <select name="level" class="form-select" required>
                                    <option value="">Select level...</option>
                                    <option>Beginner</option>
                                    <option>Intermediate</option>
                                    <option>Advanced</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea name="description" class="form-control" rows="4"
                                      placeholder="Describe what students will learn..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Estimated Hours</label>
                            <input type="number" name="estimatedHours" class="form-control" value="0" min="0" max="500" />
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary px-5">
                                <i class="fas fa-plus me-2"></i>Create Course
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>