@model IEnumerable<LanguageLearningPlatform.Data.Models.Course>

@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="container my-5">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fw-bold mb-1"><i class="fas fa-chalkboard-teacher me-2 text-primary"></i>Teacher Dashboard</h1>
            <p class="text-secondary mb-0">Manage your courses and track student progress</p>
        </div>
        <a asp-action="CreateCourse" class="btn btn-primary px-4">
            <i class="fas fa-plus me-2"></i>New Course
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon primary"><i class="fas fa-book"></i></div>
                <div class="stat-value">@ViewBag.TotalCourses</div>
                <div class="stat-label">Total Courses</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon success"><i class="fas fa-globe"></i></div>
                <div class="stat-value">@ViewBag.PublishedCourses</div>
                <div class="stat-label">Published</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon warning"><i class="fas fa-users"></i></div>
                <div class="stat-value">@ViewBag.TotalStudents</div>
                <div class="stat-label">Enrolled Students</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="cursor:pointer;" onclick="location.href='@Url.Action("Messages")'">
                <div class="stat-icon @(ViewBag.UnreadMessages > 0 ? "danger" : "primary")">
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="stat-value">@ViewBag.UnreadMessages</div>
                <div class="stat-label">Unread Messages</div>
            </div>
        </div>
    </div>

    @if ((ViewBag.RecentMessages as List<LanguageLearningPlatform.Data.Models.TeacherMessage>)?.Any() == true)
    {
        <div class="card shadow-sm mb-5" style="border-radius:16px;border:none;">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0"><i class="fas fa-bell me-2 text-danger"></i>Unread Messages</h5>
                    <a asp-action="Messages" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                @foreach (var msg in (List<LanguageLearningPlatform.Data.Models.TeacherMessage>)ViewBag.RecentMessages)
                {
                    <div class="d-flex align-items-center gap-3 p-3 rounded-3 mb-2" style="background:#F9FAFB;border:1px solid #E5E7EB;">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                             style="width:40px;height:40px;font-size:0.85rem;">
                            @(msg.Student?.FirstName?.Substring(0, 1))@(msg.Student?.LastName?.Substring(0, 1))
                        </div>
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-semibold">@msg.Student?.FirstName @msg.Student?.LastName</div>
                            <div class="text-secondary small text-truncate">@msg.Message</div>
                        </div>
                        <div class="text-secondary small flex-shrink-0">@msg.SentAt.ToString("MMM dd, HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    }

    <h4 class="fw-bold mb-3"><i class="fas fa-book-open me-2 text-primary"></i>Your Courses</h4>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded-4" style="border-style:dashed!important;">
            <i class="fas fa-book" style="font-size:4rem;color:#D1D5DB;"></i>
            <h4 class="mt-3 text-secondary">No courses yet</h4>
            <p class="text-secondary">Create your first course to get started</p>
            <a asp-action="CreateCourse" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Create Course
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var course in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100" style="border-radius:16px;border:2px solid #E5E7EB;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge @(course.IsPublished ? "bg-success" : "bg-secondary")">
                                    @(course.IsPublished ? "Published" : "Draft")
                                </span>
                                <span class="badge bg-light text-dark">@course.Level</span>
                            </div>
                            <h5 class="fw-bold mt-2">@course.Title</h5>
                            <p class="text-secondary small">@course.Language</p>
                            <div class="d-flex gap-3 mb-3 small text-secondary">
                                <span><i class="fas fa-book-open me-1"></i>@course.Lessons.Count lessons</span>
                                <span><i class="fas fa-users me-1"></i>@course.Enrollments.Count students</span>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="CourseDetails" asp-route-id="@course.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye me-1"></i>Manage
                                </a>
                                <form asp-action="TogglePublish" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@course.Id" />
                                    <button type="submit" class="btn btn-sm @(course.IsPublished ? "btn-outline-warning" : "btn-outline-success")">
                                        <i class="fas fa-@(course.IsPublished ? "eye-slash" : "globe") me-1"></i>
                                        @(course.IsPublished ? "Unpublish" : "Publish")
                                    </button>
                                </form>
                                <a asp-action="Students" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-users me-1"></i>Students
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>