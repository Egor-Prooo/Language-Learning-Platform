@using LanguageLearningPlatform.Web.Controllers
@model IEnumerable<TeacherConversationViewModel>

@{
    ViewData["Title"] = "Student Messages";
}

<div class="container my-5">
    <h1 class="fw-bold mb-4"><i class="fas fa-envelope me-2 text-primary"></i>Student Messages</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded-4" style="border-style:dashed!important;">
            <i class="fas fa-envelope-open" style="font-size:4rem;color:#D1D5DB;"></i>
            <h4 class="mt-3 text-secondary">No messages yet</h4>
            <p class="text-secondary">Students will appear here when they contact you.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var conv in Model)
            {
                <div class="card shadow-sm" style="border-radius:16px;border:2px solid #E5E7EB;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                                     style="width:48px;height:48px;">
                                    @(conv.StudentName.Length > 0 ? conv.StudentName[0].ToString().ToUpper() : "?")
                                </div>
                                <div>
                                    <div class="fw-bold">@conv.StudentName</div>
                                    <div class="text-secondary small">
                                        <i class="fas fa-book me-1"></i>@conv.CourseName
                                    </div>
                                </div>
                            </div>
                            <div class="text-secondary small">@conv.LastMessageAt.ToString("MMM dd, HH:mm")</div>
                        </div>

                        <div class="d-flex flex-column gap-2 mb-3" style="max-height:250px;overflow-y:auto;">
                            @foreach (var msg in conv.Messages)
                            {
                                <div class="d-flex @(msg.IsFromTeacher ? "justify-content-end" : "justify-content-start")">
                                    <div class="p-3 rounded-3" style="max-width:75%;background:@(msg.IsFromTeacher ? "#EEF2FF" : "#F9FAFB");border:1px solid @(msg.IsFromTeacher ? "#C7D2FE" : "#E5E7EB");">
                                        <div class="small text-secondary mb-1">
                                            @(msg.IsFromTeacher ? "You" : conv.StudentName) · @msg.SentAt.ToString("MMM dd, HH:mm")
                                        </div>
                                        <div>@msg.Message</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <form asp-action="ReplyMessage" method="post" class="d-flex gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="studentId" value="@conv.StudentId" />
                            <input type="hidden" name="courseId" value="@conv.CourseId" />
                            <input type="text" name="message" class="form-control" placeholder="Type your reply..." required />
                            <button type="submit" class="btn btn-primary px-4 flex-shrink-0">
                                <i class="fas fa-paper-plane me-1"></i>Send
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>